---
import { Image } from "astro:assets";
import { ArrowUpRight } from "lucide-react";

interface Props {
  title: string;
  imageSrc: any; // Changed from string to accept image metadata
}

const { title, imageSrc } = Astro.props;
---
<div class="bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] overflow-hidden border border-gray-100 flex flex-col group hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300">
  {/* Mock Browser Header */}
  <div class="bg-gray-50 px-4 py-3 flex items-center border-b border-gray-100">
    <div class="flex gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
    </div>
  </div>
  
  {/* Image Container */}
  <div class="relative aspect-16/10 bg-gray-100 overflow-hidden">
    <Image 
      src={imageSrc} 
      alt={title} 
      width={800}
      height={500}
      format="webp"
      class="w-full h-full object-cover object-top"
    />
  </div>

  {/* Footer */}
  <div class="p-5 flex items-center justify-between mt-auto bg-white">
    <h4 class="font-bold text-gray-800 text-lg">{title}</h4>
    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-blue-50 group-hover:text-blue-500 transition-colors">
      <ArrowUpRight className="w-4 h-4" />
    </div>
  </div>
</div>
