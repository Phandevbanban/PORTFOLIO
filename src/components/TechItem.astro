---
interface Props {
  name: string;
}

const { name } = Astro.props;
---
<div class="flex items-center gap-3 p-1 rounded-lg hover:bg-gray-50 transition-colors group">
  <div class="w-8 h-8 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all duration-300">
    <slot />
  </div>
  <span class="text-[14px] text-gray-600 group-hover:text-gray-900 transition-colors">{name}</span>
</div>
