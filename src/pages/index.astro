---
import Layout from '../layouts/Layout.astro';
import TechItem from '../components/TechItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceItem from '../components/ExperienceItem.astro';

import {
  HtmlIcon, CssIcon, JsIcon, TsIcon, NextIcon, TailwindIcon, 
  ShadcnIcon, GitIcon, ReactIcon, MySQLIcon, NestIcon, DockerIcon, RedisIcon,
  ChatIcon, CodeIcon, ArrowDownIcon
} from '../components/Icons';

// Import project images for optimization
import cscPosImg from '../assets/images/project/csc-pos/pos-dashboard.png';
import cscVehicleImg from '../assets/images/project/csc-vehicle-booking/vehicle-list.png';
import coffeePosImg from '../assets/images/project/pos-coffee/coffee-pos.png';
import ebookImg from '../assets/images/project/e-book/elibrary.png';

---

<Layout title="Phanvilay Xaphakdy | Full-Stack Web Developer">
  <div class="max-w-6xl mx-auto px-6 py-12 md:px-12 md:py-24">
    
    <!-- Header Section -->
    <header class="mb-24 lg:mb-32">
      <div 
        class="inline-flex items-center gap-2.5 bg-blue-50 text-blue-600 rounded-full px-5 py-2 text-sm font-semibold mb-8 border border-blue-100" 
        aria-label="Available for new projects badge"
      >
        <ChatIcon />
        <span>Available for new projects</span>
      </div>

      
      <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 tracking-tight leading-[1.1] mb-6 font-outfit">
        I'm Phanvilay <span class="text-blue-600">XAPHAKDY</span>
      </h1>
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-500 tracking-tight mb-10 max-w-2xl">
        A Full-Stack Web Developer building high-performance, clean & minimal digital experiences.
      </h2>
      
      <p class="max-w-xl text-gray-600 font-medium leading-[1.7] text-lg">
        Specializing in modern web technologies with a focus on code quality, performance, and exceptional user experience across the full stack.
      </p>
    </header>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
      
      <!-- Left Column: Tools & Experience -->
      <div class="lg:col-span-4 space-y-20">
        <!-- Tools Section -->
        <section>
          <div class="flex items-center gap-3 mb-10 text-gray-900">
            <CodeIcon />
            <h3 class="font-bold text-xl font-outfit uppercase tracking-wider">Tech Stack</h3>
          </div>
          
          <div class="grid grid-cols-2 gap-y-8 gap-x-4 text-[15px] font-semibold text-gray-600">
            <TechItem name="HTML"><HtmlIcon /></TechItem>
            <TechItem name="CSS"><CssIcon /></TechItem>
            <TechItem name="JavaScript"><JsIcon /></TechItem>
            <TechItem name="TypeScript"><TsIcon /></TechItem>
            <TechItem name="Next.js"><NextIcon /></TechItem>
            <TechItem name="React"><ReactIcon /></TechItem>
            <TechItem name="Tailwind CSS"><TailwindIcon /></TechItem>
            <TechItem name="Shadcn UI"><ShadcnIcon /></TechItem>
            <TechItem name="NestJS"><NestIcon /></TechItem>
            <TechItem name="MySQL"><MySQLIcon /></TechItem>
            <TechItem name="Docker"><DockerIcon /></TechItem>
            <TechItem name="Redis"><RedisIcon /></TechItem>
            <TechItem name="Git"><GitIcon /></TechItem>
          </div>
        </section>

        <!-- Experience Section Short -->
        <section>
          <h3 class="text-xl font-bold text-gray-900 mb-10 font-outfit uppercase tracking-wider">Experience</h3>
          <div class="space-y-12">
            <ExperienceItem
              title="Full-Stack Web Developer"
              company="CSC Complex Center Co, Ltd"
              date="2024 - Present"
              descriptions={[]}
            />
            <ExperienceItem
              title="Front-End Developer"
              company="Houng Ah Loun Technology"
              date="2023 - 2024"
              descriptions={[]}
            />
          </div>
        </section>
      </div>

      <!-- Right Column: Projects -->
      <div class="lg:col-span-8">
        <div class="flex items-center justify-between mb-12">
          <h3 class="text-3xl font-bold text-gray-900 font-outfit">Selected Work</h3>
          <span class="text-sm font-bold text-blue-600 uppercase tracking-widest">Recent Projects</span>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <ProjectCard 
            title="CSC-POS System" 
            imageSrc={cscPosImg} 
          />
          <ProjectCard 
            title="CSC Vehicle Booking" 
            imageSrc={cscVehicleImg} 
          />
          <ProjectCard 
            title="Coffee POS" 
            imageSrc={coffeePosImg} 
          />
          <ProjectCard 
            title="E-BOOK Library" 
            imageSrc={ebookImg} 
          />
        </div>
      </div>
    </div>

    <!-- Final CTA/Footer -->
    <footer class="mt-32 pt-16 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-8 text-gray-500 text-sm font-medium">
      <p>&copy; 2026 Phanvilay XAPHAKDY. All rights reserved.</p>
      <button 
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        aria-label="Scroll to top"
        class="w-12 h-12 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:text-blue-500 hover:border-blue-500 transition-all cursor-pointer bg-transparent focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
      >
        <ArrowDownIcon />
      </button>
    </footer>

  </div>
</Layout>
